{
  "name": "polygon-checkpoint-indexer",
  "version": "1.0.0",
  "description": "Envio HyperIndex indexer for Polygon PoS checkpoints + validator signing attribution (Ethereum L1)",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "codegen": "ENVIO_ETHEREUM_MAINNET_HYPERRPC_URL=https://1.rpc.hypersync.xyz/build-token ENVIO_ETHEREUM_MAINNET_LIVE_HEAD_RPC_URL=http://localhost:8545 ENVIO_ETHEREUM_MAINNET_LIVE_HEAD_WS_URL=ws://localhost:8546 envio codegen",
    "dev": "envio dev",
    "start": "envio start",
    "stop": "envio stop",
    "selfcheck": "node scripts/selfcheck.mjs"
  },
  "dependencies": {
    "envio": "3.2.1",
    "viem": "2.21.55"
  },
  "devDependencies": {
    "typescript": "5.6.3"
  }
}
