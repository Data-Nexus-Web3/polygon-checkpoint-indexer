# RPC endpoints referenced by config.yaml (chains[0].rpc). Supplied at runtime
# (e.g. by the EnvioIndexer operator). HyperSync remains the primary data source
# and serves both logs and the transaction calldata this indexer needs; these
# RPCs are for the HyperRPC fallback and live-head/realtime tracking.
ENVIO_ETHEREUM_MAINNET_HYPERRPC_URL=https://eth.rpc.hypersync.xyz
ENVIO_ETHEREUM_MAINNET_LIVE_HEAD_RPC_URL=https://<mainnet-rpc>.rpcs.svc.cluster.local:8545
ENVIO_ETHEREUM_MAINNET_LIVE_HEAD_WS_URL=wss://<mainnet-rpc>.rpcs.svc.cluster.local:8546

# Envio hosted-service token (only needed for `envio init` / hosted deploy, not dev):
# ENVIO_API_TOKEN=
