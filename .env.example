# HyperSync serves both logs AND the transaction calldata this indexer needs
# (field_selection.transaction_fields: [hash, input]) for Ethereum mainnet, so no
# RPC is required for normal operation.
#
# Optional: set a mainnet execution RPC as a HyperSync fallback for added
# reliability (uncomment and point at your in-cluster RPC or a provider):
# ENVIO_RPC_URL_1=http://<mainnet-rpc>.rpcs.svc.cluster.local:8545

# Envio hosted-service token (only needed for `envio init` / hosted deploy, not dev):
# ENVIO_API_TOKEN=
